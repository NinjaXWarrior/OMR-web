# FastAPI backend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Clerk — create an app at https://dashboard.clerk.com and copy both keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
